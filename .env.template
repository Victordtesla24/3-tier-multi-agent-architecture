# Tier model precedence:
#   1. ORCHESTRATION_MODEL / L1_MODEL / L2_MODEL / L3_MODEL
#   2. PRIMARY_LLM as orchestration fallback / legacy compatibility
#   3. Catalog defaults from src/engine/model_catalog.py
#
# Accepted logical IDs:
#   openai/gpt-5.4
#   openai/gpt-5.2-codex
#   gemini/gemini-3.1-pro-preview
#   deepseek/deepseek-chat
#   ollama/qwen3:14b
#   ollama/qwen3:8b
#   ollama/qwen2.5-coder:14b
#   ollama/qwen2.5-coder:7b
PRIMARY_LLM=openai/gpt-5.4
ORCHESTRATION_MODEL=openai/gpt-5.4
L1_MODEL=gemini/gemini-3.1-pro-preview
L2_MODEL=ollama/qwen3:8b
L3_MODEL=ollama/qwen2.5-coder:7b
L2_AGENT_SWARMS=2
L3_AGENT_SWARMS=3

# Primary Orchestration & L1 Model Keys
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Legacy alias keys remain accepted for compatibility:
# GEMINI_API_KEY=

# Optional API-backed provider:
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Local Open-Source Provider URL
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional: CrewAI Memory Storage (defaults to <workspace>/.agent/memory/crewai_storage)
# CREWAI_STORAGE_DIR=
