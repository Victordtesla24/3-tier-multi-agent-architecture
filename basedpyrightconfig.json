{
  "include": [
    "src",
    "tests",
    "main.py",
    "benchmarks/run_benchmark.py",
    "examples/general_llm/main.py",
    "scripts/validate_runtime_env.py"
  ],
  "exclude": [
    "**/__pycache__",
    ".venv",
    "node_modules",
    ".git"
  ],
  "venvPath": ".",
  "venv": ".venv",
  "pythonVersion": "3.12",
  "typeCheckingMode": "basic",
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": ["src"]
    },
    {
      "root": "src",
      "extraPaths": ["src"]
    },
    {
      "root": "tests",
      "extraPaths": ["src"]
    },
    {
      "root": "benchmarks",
      "extraPaths": ["src"]
    },
    {
      "root": "examples",
      "extraPaths": ["src"]
    },
    {
      "root": "scripts",
      "extraPaths": ["src"]
    }
  ]
}
