{
  "include": ["src", "tests"],
  "exclude": [
    "**/__pycache__",
    ".venv",
    "node_modules",
    ".git"
  ],
  "venvPath": ".",
  "venv": ".venv",
  "pythonVersion": "3.12",
  "typeCheckingMode": "basic",
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": ["src"]
    },
    {
      "root": "src",
      "extraPaths": ["src"]
    },
    {
      "root": "tests",
      "extraPaths": ["src"]
    }
  ]
}
